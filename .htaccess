RewriteEngine On

# ── Clean URLs: hide .html extension from browser bar ────────────────────
# Rule 1: /index or /index.html → redirect to bare /
RewriteCond %{THE_REQUEST} \s/+index(\.html)?[\s?] [NC]
RewriteRule ^ / [R=301,L]

# Rule 2: /page.html → /page  (301 permanent redirect)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Rule 3: /page → internally serve page.html (no visible redirect)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]

# ── Protect admin panel ───────────────────────────────────────────────────
# Apache 2.4 syntax: only the whitelisted IP gets through.
# /admin and /admin.html are both blocked for everyone else.
<Files "admin.html">
  Require ip 158.140.180.78
</Files>
